# Optional: WalletConnect Cloud (https://cloud.walletconnect.com). Unset = RainbowKit demo project.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# RSK network for wallet + on-chain APY reads: 30 = mainnet, 31 = testnet (default 30)
NEXT_PUBLIC_RSK_CHAIN_ID=

# Deployed YieldRouter (same chain as NEXT_PUBLIC_RSK_CHAIN_ID)
NEXT_PUBLIC_YIELD_ROUTER=
